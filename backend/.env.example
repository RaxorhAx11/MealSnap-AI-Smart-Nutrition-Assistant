# Copy to .env and set your values. Do not commit .env.

# Required in production. For local dev, a default is used if unset.
JWT_SECRET_KEY=your-secret-key-min-32-chars-for-hs256

# Optional. Default: sqlite:///./mealsnap.db (created in backend/ when running from backend/)
# DATABASE_URL=sqlite:///./mealsnap.db
